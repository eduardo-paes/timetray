{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TimeTray",
  "version": "0.1.0",
  "identifier": "com.timetray.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TimeTray",
        "width": 1180,
        "height": 760,
        "minWidth": 980,
        "minHeight": 640,
        "center": true,
        "resizable": true,
        "decorations": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "© 2026 Eduardo Paes",
    "category": "Productivity",
    "shortDescription": "Minimal system tray time tracker for engineers",
    "longDescription": "TimeTray is a precision desktop time tracking utility that lives in the system tray. Switch tasks instantly, review daily summaries, and stay focused — no accounts, no cloud, no noise.",
    "windows": {
      "nsis": {
        "languages": ["English"],
        "displayLanguageSelector": false,
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:timetray.db"]
    }
  }
}
